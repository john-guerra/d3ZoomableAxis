{
  "name": "@john-guerra/d3-zoomable-axis",
  "version": "0.0.1",
  "description": "A d3 axis you can drag to zoom: combines a d3 axis with a dual-handle range control. Pure-d3 idiom + optional reactive-widget input.",
  "keywords": [
    "d3",
    "d3-module",
    "axis",
    "slider",
    "range",
    "zoom",
    "brush",
    "reactive-widgets"
  ],
  "license": "ISC",
  "author": "John Alexis Guerra Gómez",
  "homepage": "https://github.com/john-guerra/d3ZoomableAxis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/john-guerra/d3ZoomableAxis.git"
  },
  "type": "module",
  "main": "src/index.js",
  "module": "src/index.js",
  "jsdelivr": "dist/d3-zoomable-axis.min.js",
  "unpkg": "dist/d3-zoomable-axis.min.js",
  "exports": {
    "umd": "./dist/d3-zoomable-axis.min.js",
    "default": "./src/index.js"
  },
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "src/**/*.js"
  ],
  "scripts": {
    "test": "node --test",
    "build": "rollup -c",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "d3-axis": "1 - 3",
    "d3-brush": "1 - 3",
    "d3-dispatch": "1 - 3",
    "d3-scale": "1 - 4",
    "d3-selection": "1 - 3",
    "d3-shape": "^3.2.0",
    "fast-kde": "^0.2.2"
  },
  "peerDependencies": {
    "reactive-widget-helper": "^0.0.3"
  },
  "peerDependenciesMeta": {
    "reactive-widget-helper": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "reactive-widget-helper": "^0.0.3",
    "rollup": "^4.0.0"
  }
}
